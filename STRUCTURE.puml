' Relaciones dentro de microservicios (patrón Repository)
AuthController --> AuthService
AuthService --> UserRepository
UserRepository --> User
AuthService ..> LoginRequestDTO : usa
AuthService ..> LoginResponseDTO : retorna
AuthServiceTest --> AuthService : @InjectMocks

CatalogController --> CatalogService
CatalogService --> CatalogRepository
CatalogRepository --> ProductCatalog
CatalogServiceTest --> CatalogService : @InjectMocks

ProcurementController --> ProcurementService
